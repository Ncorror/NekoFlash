<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="NekoFlashThemeBase" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent_pressed</item>
        <item name="colorOnPrimary">@color/on_accent</item>
        <item name="colorSecondary">@color/accent_soft</item>
        <item name="colorOnSecondary">@color/on_accent</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:colorBackground">@color/bg_base</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/bg_base</item>
        <item name="android:statusBarColor">@color/bg_base</item>
        <item name="android:navigationBarColor">@color/bg_base</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.NekoFlash.AlertDialog</item>
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.NekoFlash.BottomSheetDialog</item>
    </style>

    <style name="Theme.NekoFlash" parent="@style/NekoFlashThemeBase" />

    <style name="ThemeOverlay.NekoFlash.AlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorSurface">@color/bg_elevated</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <style name="ThemeOverlay.NekoFlash.BottomSheetDialog" parent="ThemeOverlay.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.NekoFlash.BottomSheet</item>
    </style>

    <style name="Widget.NekoFlash.BottomSheet" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="android:background">@drawable/bg_bottom_sheet</item>
    </style>

    <!-- V5.8.9: clear interactive states without adding more orange surfaces. -->
    <style name="Widget.NekoFlash.PartitionTile" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">@color/nf_action_tile_text</item>
        <item name="android:elevation">0dp</item>
        <item name="backgroundTint">@color/nf_action_tile_background</item>
        <item name="strokeColor">@color/nf_action_tile_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="rippleColor">@color/nf_button_ripple</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.NekoFlash.QueueTile" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">@color/nf_queue_tile_text</item>
        <item name="android:elevation">0dp</item>
        <item name="backgroundTint">@color/nf_queue_tile_background</item>
        <item name="strokeColor">@color/nf_queue_tile_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="rippleColor">@color/nf_button_ripple</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.NekoFlash.ProfileTile" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">@color/nf_profile_tile_text</item>
        <item name="android:elevation">0dp</item>
        <item name="backgroundTint">@color/nf_profile_tile_background</item>
        <item name="strokeColor">@color/nf_profile_tile_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="rippleColor">@color/nf_button_ripple</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.NekoFlash.SecondaryAction" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/nf_action_tile_text</item>
        <item name="android:elevation">0dp</item>
        <item name="backgroundTint">@color/nf_action_tile_background</item>
        <item name="strokeColor">@color/nf_action_tile_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="rippleColor">@color/nf_button_ripple</item>
        <item name="cornerRadius">12dp</item>
    </style>

</resources>
